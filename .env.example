# LAID Growth Engine — Environment Variables
# Copy to .env.local for development, set in Vercel for production

# Supabase (free tier)
# Get from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Stripe (test keys for now, swap to live for production)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server-only (used by /api routes — DO NOT prefix with VITE_)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi... # for server-side admin operations

# fal.ai (video + image generation)
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=key-id:key-secret

# OpenAI (script + content generation)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ElevenLabs (voice cloning, optional - Kling generates audio natively)
ELEVENLABS_API_KEY=

# App config
VITE_APP_URL=http://localhost:5173
VITE_FOUNDING_PRICE_USD=1997
VITE_FOUNDING_CAP=50
